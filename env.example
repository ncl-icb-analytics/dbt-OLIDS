# dbt Environment Configuration
# Copy this to .env and configure with your credentials
# Never commit .env to version control

SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your.email@nhs.net
SNOWFLAKE_ROLE=your-role
SNOWFLAKE_WAREHOUSE=your-warehouse
SNOWFLAKE_TARGET_DATABASE=DATA_LAB_OLIDS_NCL

# Authenticator: 'username_password_mfa' for PAT/password, 'externalbrowser' for SSO
SNOWFLAKE_AUTHENTICATOR=username_password_mfa

# Snowflake Password (PAT token recommended — skips browser login)
SNOWFLAKE_PASSWORD=your-programmatic-access-token